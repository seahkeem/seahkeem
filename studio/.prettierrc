{
  "semi": true,
  "singleQuote": true,
  "trailingComma": "es5",
  "endOfLine": "lf",
  "insertFinalNewline": true,
  "trimTrailingWhitespace": true,
  "plugins": ["prettier-plugin-tailwindcss"],
  "tailwindStylesheet": "./app/globals.css",
  "tailwindAttributes": ["myClassList", "/data-.*/"],
  "tailwindFunctions": ["clsx"]
}
